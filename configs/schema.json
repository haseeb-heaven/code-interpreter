{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Code Interpreter Model Config",
  "type": "object",
  "properties": {
    "model": { "type": "string" },
    "provider": { "type": "string" },
    "api_base": { "type": ["string", "null"] },
    "temperature": { "type": "number" },
    "max_tokens": { "type": "integer" },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "description": "Per-request timeout in seconds"
    },
    "rate_limits": {
      "type": "object",
      "properties": {
        "rpm": { "type": "number", "minimum": 1, "default": 60 },
        "burst": { "type": "integer", "minimum": 1, "default": 10 }
      },
      "additionalProperties": false
    },
    "circuit_breaker": {
      "type": "object",
      "properties": {
        "threshold": { "type": "integer", "minimum": 1, "default": 3 },
        "cooldown_seconds": { "type": "number", "minimum": 0.1, "default": 120 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
