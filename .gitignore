# API keys and secrets
.env
.env~

# Live-testing harness reports (scripts/live-test) — local debugging only,
# never committed since they contain real prompts/outputs from real API calls.
/.live-test-reports/

# Windows sandbox helper is compiled from OpenAgentSandbox.cs by
# packages/core/scripts/compile-windows-sandbox.js — never commit the binary.
packages/core/src/sandbox/windows/OpenAgentSandbox.exe
packages/core/dist/src/sandbox/windows/OpenAgentSandbox.exe

# OpenAgent settings
# We want to keep the .openagent in the root of the repo and ignore any
# .openagent in subdirectories. In our root .openagent we want to allow for
# version control for subcommands.
**/.openagent/
!/.openagent/
.openagent/*
!.openagent/commands/
!.openagent/skills/
!.openagent/settings.json

# Legacy .gemini dirs elsewhere in the tree (e.g. clipboard scratch space)
**/.gemini/

# Note: .openagent-clipboard/ is NOT in gitignore so OpenAgent can access pasted images

# Dependency directory
node_modules
bower_components

# Editors
.idea
*.iml

# OS metadata
.DS_Store
Thumbs.db

# TypeScript build info files
*.tsbuildinfo

# Ignore built ts files
dist

# Docker folder to help skip auth refreshes
.docker

bundle

# Test report files
junit.xml
packages/*/coverage/

# Generated files
packages/cli/src/generated/
packages/core/src/generated/
packages/devtools/src/_client-assets.ts
.integration-tests/
.perf-tests/
packages/vscode-ide-companion/*.vsix
packages/cli/download-ripgrep*/

# GHA credentials
gha-creds-*.json

# Log files
patch_output.log
gemini-debug.log

.genkit
.gemini-clipboard/
.eslintcache
evals/logs/

temp_agents/

# conductor extension and planning directories
conductor/

# Python "Open Code Interpreter" project artifacts (unrelated product,
# lives on the develop branch — must never be committed to this branch)
/.venv/
/__pycache__/
/.pytest_cache/
/build/
/scratch/
/output/
/history/
/htmlcov_focus/
/logs/
/libs/
/tests/
/scripts/__pycache__/
/packages/cli/packages/
/CLAUDE.md
/CLAUDE.local.md
