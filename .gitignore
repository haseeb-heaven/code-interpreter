# Byte-compiled / optimized / DLL files
*.pyc
*.pyo
*.pyd
__pycache__/
.pytest_cache/

# Log files
*.log
/logs/
logs/*

# macOS system files
.DS_Store

# Environment files
*.env
.env
.env.local
.env.*.local

# Virtual environments
venv/
myvenv/
heaven_venv/
.venv/
node_modules/

# Interactive environment data
interp/

# Generated output files and directories
output/
logs/
dist/
*.tmp
*.bak

# JSON files (ignore ALL json files)
*.json

# BUT keep config JSONs
!configs/
!configs/*.json

# History files (explicitly ignored)
history.json
history/

# Keep placeholder only
!history/.gitkeep

# Local test/diagnostic artifacts
debug_output*.txt
test_results*.txt
groq_test.txt
gemini_models.txt

# Editor and IDE specific files
.vscode/
.idea/
*.sublime-workspace

# OS-specific files
Thumbs.db
ehthumbs.db
desktop.ini
*.ps1
*.cmd